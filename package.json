{
  "name": "ollama-code",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ollama-code — local agentic coding CLI for Qwen 3.5 via Ollama (native /api/chat).",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ollama-code": "bin/ollama-code.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "ink": "^6.0.0",
    "ollama": "^0.6.0",
    "react": "^19.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "optionalDependencies": {
    "sharp": "^0.33.0"
  }
}
